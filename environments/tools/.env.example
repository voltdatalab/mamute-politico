# Opções de configuração (setup)
# app_stack: Proxy reverso + Ghost (+ ghost-db) + UI + API + Chatbot
ACTIVE_APP_STACK=true
ACTIVE_SCRAPPERS=false
# Banco de dados controla apenas pgvector-db
ACTIVE_DATABASE=false

# API mode (aplica-se apenas quando ACTIVE_APP_STACK=true): all_together | remote
API_MODE=all_together
REMOTE_API_BASE_URL=

# Chatbot mode (aplica-se apenas quando ACTIVE_APP_STACK=true): all_together | remote
CHATBOT_MODE=all_together
REMOTE_CHATBOT_BASE_URL=

# Public entrypoint for app stack (Caddy/Ghost/UI)
PUBLIC_BASE_URL=http://localhost
