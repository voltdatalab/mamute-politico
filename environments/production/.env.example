# Copy to .env in this directory and adjust for your production deployment.

# Browser-facing URL for Ghost and site links.
PUBLIC_URL=http://localhost

# MySQL root password for the Ghost database (Ghost uses the same value).
GHOST_DB_PASSWORD=change_me

# Host port for Caddy HTTP listener.
CADDY_HTTP_PORT=80

# Chatbot: create chatbot_backend/.env (see that README). Caddy routes /chat* to the chatbot container; the UI calls POST /chat/chatbot/stream on the same origin.

