# API base URL (no trailing slash). Required for data routes; must include the /api prefix.
# Example: http://127.0.0.1:8000/api
VITE_API_BASE_URL=

# Chatbot: leave unset to use same-origin /chat/... (Caddy on :80 in environments/development).
# If the chatbot is on another origin, set full origin only (no path), e.g. https://chatbot.example.com
# VITE_CHATBOT_BASE_URL=http://127.0.0.1:8000

# Ghost auth origin (for login portal and token endpoint).
# VITE_AUTH_API_ROOT=https://mamute-ghost.example.com
#
# With Caddy + Ghost in environments/development (app at /app/, Ghost on :80):
# VITE_AUTH_API_ROOT=http://localhost
#
# CORS: The Ghost server MUST allow credentialed requests from your app origin.
# It cannot use Access-Control-Allow-Origin: * when credentials are used.
# Configure the Ghost host/proxy to respond with:
#   Access-Control-Allow-Origin: <your app origin, e.g. http://localhost:8080, http://localhost (Caddy + /app/), or https://app.example.com>
#   Access-Control-Allow-Credentials: true
# for the path /members/api/session (and optionally /members/.well-known/jwks.json).

# Ghost JWKS JSON string (optional). From {VITE_AUTH_API_ROOT}/members/.well-known/jwks.json
# If omitted, token is still stored and sent; verification can be done on the backend.
# VITE_GHOST_JWKS=

# Ghost Members JWT. Optional fallback for local dev; in production use the login button.
# VITE_GHOST_MEMBER_TOKEN=

# Optional: project ID for "monitored parliamentarians" on the dashboard.
# If set, the dashboard will show favorites from GET /api/projects/{id}/favorites.
# If unset, the dashboard falls back to the first N parliamentarians from the list.
# VITE_PROJECT_ID=1
